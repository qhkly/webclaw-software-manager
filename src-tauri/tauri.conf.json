{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Webclaw Software Manager",
  "version": "0.1.0",
  "identifier": "com.land007.webclaw-software-manager",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Webclaw Software Manager",
        "width": 1120,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["/opt/on-demand-icons/**", "/opt/desktop-icons/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Webclaw 跨平台软件管理器",
    "longDescription": "按当前平台展示可用软件，支持安装、检测版本、检查更新与离线 manifest 回退。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    },
    "resources": [
      "../software-manifest.json"
    ]
  }
}
