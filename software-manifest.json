{
  "$schema": "./software-manifest.schema.json",
  "version": "0.1.0",
  "_remote_url": "https://raw.githubusercontent.com/qhkly/webclaw-software-manager/main/software-manifest.json",
  "software": [
    {
      "id": "claude-code",
      "name": "Claude Code CLI",
      "category": "ai-cli",
      "group": "ai",
      "risk": "low",
      "desc": "AI 编程命令行",
      "platforms": {
        "container": {
          "detect": { "type": "npm-global", "pkg": "@anthropic-ai/claude-code" },
          "latest": { "type": "npm-registry", "pkg": "@anthropic-ai/claude-code" },
          "install": { "type": "npm-global", "pkg": "@anthropic-ai/claude-code" }
        },
        "macos": {
          "detect": { "type": "shell", "cmd": "claude --version 2>&1", "version_regex": "([0-9]+\\.[0-9]+\\.[0-9]+)" },
          "latest": { "type": "npm-registry", "pkg": "@anthropic-ai/claude-code" },
          "install": { "type": "npm-global", "pkg": "@anthropic-ai/claude-code" }
        },
        "windows": {
          "detect": { "type": "shell", "cmd": "claude --version", "version_regex": "([0-9]+\\.[0-9]+\\.[0-9]+)" },
          "latest": { "type": "npm-registry", "pkg": "@anthropic-ai/claude-code" },
          "install": { "type": "npm-global", "pkg": "@anthropic-ai/claude-code" }
        }
      }
    },
