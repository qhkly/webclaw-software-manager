    {
      "id": "opencode",
      "name": "OpenCode",
      "name_zh": "OpenCode AI CLI",
      "category": "ai",
      "group": "ai",
      "risk": "low",
      "desc": "开源 AI 编程命令行工具",
      "platforms": {
        "container": {
          "detect": {
            "type": "binary",
            "path": "/usr/local/bin/opencode"
          },
          "latest": {
            "type": "github-release-latest",
            "repo": "opencode-ai/opencode"
          },
          "install": {
            "type": "custom-script",
            "script": "/opt/install-scripts/install-opencode.sh"
          },
          "upgrade": {
            "type": "custom-script",
            "script": "/opt/install-scripts/install-opencode.sh"
          }
        },
        "macos": {
          "detect": {
            "type": "shell",
            "cmd": "opencode --version 2>/dev/null || /usr/local/bin/opencode --version 2>/dev/null",
            "version_regex": "([0-9]+\\.[0-9]+\\.[0-9]+)"
          },
          "latest": {
            "type": "github-release-latest",
            "repo": "opencode-ai/opencode"
          },
          "install": {
            "type": "shell",
            "cmd": "ARCH=$(uname -m | sed 's/x86_64/amd64/') && TAG=$(curl -fsSL -o /dev/null -w '%{url_effective}' 'https://github.com/opencode-ai/opencode/releases/latest' | sed 's|.*/tag/v||' | tr -d '\\r') && curl -fsSL -L \"https://github.com/opencode-ai/opencode/releases/download/v${TAG}/opencode_${TAG}_darwin_${ARCH}.tar.gz\" | tar -xz -C /tmp opencode && mv /tmp/opencode /usr/local/bin/opencode && chmod +x /usr/local/bin/opencode"
          }
        }
      },
      "icon": "/opt/on-demand-icons/opencode.png"
    },
