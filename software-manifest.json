          "latest": { "type": "npm-registry", "pkg": "@openai/codex" },
          "install": { "type": "npm-global", "pkg": "@openai/codex" }
        },
        "windows": {
          "detect": { "type": "shell", "cmd": "codex --version", "version_regex": "([0-9]+\\.[0-9]+\\.[0-9]+)" },
          "latest": { "type": "npm-registry", "pkg": "@openai/codex" },
          "install": { "type": "npm-global", "pkg": "@openai/codex" }
        }
      }
    },
